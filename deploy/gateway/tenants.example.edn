;; Lodestar gateway tenant registry (example).
;; Copy to tenants.edn (gitignored) — or let provision.sh manage it.
;;
;; One entry per tenant: a sha-256 hex of the tenant's bearer token (never the
;; plaintext token), and the loopback port of that tenant's own coordinator.
;; Each tenant is a fully isolated coordinator + claims.log — the only safe
;; tenancy boundary (the per-assertion `frame` is provenance, not authorization).
{"acme"   {:token-sha256 "REPLACE_WITH_SHA256_OF_ACME_TOKEN"   :coordinator-port 7801}
 "globex" {:token-sha256 "REPLACE_WITH_SHA256_OF_GLOBEX_TOKEN" :coordinator-port 7802}}
