{
  "private": true,
  "name": "lodestar-theia",
  "version": "0.1.0",
  "theia": {
    "frontend": {
      "config": {
        "applicationName": "Lodestar Editor",
        "preferences": {
          "files.enableTrash": false
        }
      }
    }
  },
  "dependencies": {
    "@theia/core": "1.73.0",
    "@theia/editor": "1.73.0",
    "@theia/filesystem": "1.73.0",
    "@theia/markers": "1.73.0",
    "@theia/messages": "1.73.0",
    "@theia/monaco": "1.73.0",
    "@theia/navigator": "1.73.0",
    "@theia/preferences": "1.73.0",
    "@theia/process": "1.73.0",
    "@theia/terminal": "1.73.0",
    "@theia/workspace": "1.73.0",
    "@theia/file-search": "1.73.0"
  },
  "devDependencies": {
    "@theia/cli": "1.73.0"
  },
  "scripts": {
    "prepare": "theia build --mode development",
    "start": "theia start --hostname 127.0.0.1 --port 3000 /home/tom/code",
    "build": "theia build"
  }
}
